generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PaymentStatus {
  unpaid
  partial
  paid
  returned
  cancelled
}

enum CourierStatus {
  pending
  dispatched
  in_transit
  delivered
  returned
  failed
}

enum StockMovementType {
  opening
  production_in
  sale_out
  return_in
  adjustment
}

enum AuthRole {
  admin
  staff
  viewer
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  role         AuthRole
  passwordHash String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investors Investor[]
}

model Investor {
  id               String   @id @default(cuid())
  companyId        String
  name             String
  investmentAmount Decimal  @db.Decimal(12, 2)
  ownershipPercent Decimal  @db.Decimal(5, 2)
  profitSharePercent Decimal @db.Decimal(5, 2)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model ProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]
}

model ProductVariant {
  id         String   @id @default(cuid())
  categoryId   String
  model        String
  color        String?
  size         String?
  sku          String?  @unique
  openingStock Int      @default(0)
  reorderLevel Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  ledgerEntries StockLedger[]
  productionBatches ProductionBatch[]
  invoiceItems SalesInvoiceItem[]

  @@index([categoryId])
}

model ProductionBatch {
  id            String   @id @default(cuid())
  productVariantId String
  batchDate        DateTime
  materialCost     Decimal  @db.Decimal(12, 2)
  laborCost        Decimal  @db.Decimal(12, 2)
  packagingCost    Decimal  @db.Decimal(12, 2)
  otherCost        Decimal  @db.Decimal(12, 2)
  quantity         Int
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([productVariantId])
}

model StockLedger {
  id              String           @id @default(cuid())
  productVariantId String
  movementType    StockMovementType
  quantity        Int
  movementDate    DateTime
  referenceType   String?
  referenceId     String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([productVariantId])
  @@index([movementType])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  mobile    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices SalesInvoice[]
}

model SalesInvoice {
  id            String         @id @default(cuid())
  invoiceNo     String         @unique
  customerId    String?
  invoiceDate   DateTime
  paymentStatus PaymentStatus
  totalSale     Decimal        @db.Decimal(12, 2)
  totalCost     Decimal        @db.Decimal(12, 2)
  netProfit     Decimal        @db.Decimal(12, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    SalesInvoiceItem[]
  shipment CourierShipment?

  @@index([customerId])
}

model SalesInvoiceItem {
  id                String   @id @default(cuid())
  salesInvoiceId     String
  productVariantId   String
  quantity          Int
  sellingPrice      Decimal  @db.Decimal(12, 2)
  productionCostUnit Decimal  @db.Decimal(12, 2)
  courierCost       Decimal  @db.Decimal(12, 2)
  adsCost           Decimal  @db.Decimal(12, 2)
  packagingCost     Decimal  @db.Decimal(12, 2)
  totalSale         Decimal  @db.Decimal(12, 2)
  totalCost         Decimal  @db.Decimal(12, 2)
  netProfit         Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invoice        SalesInvoice   @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([salesInvoiceId])
  @@index([productVariantId])
}

model CourierShipment {
  id             String         @id @default(cuid())
  salesInvoiceId  String?        @unique
  shipmentDate    DateTime
  courierName     String
  trackingId      String?
  status          CourierStatus
  deliveryCharge  Decimal        @db.Decimal(12, 2)
  codCharge       Decimal        @db.Decimal(12, 2)
  returnCharge    Decimal        @db.Decimal(12, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  salesInvoice SalesInvoice? @relation(fields: [salesInvoiceId], references: [id], onDelete: SetNull)

  @@index([status])
}

model OfficeExpense {
  id          String   @id @default(cuid())
  expenseDate DateTime
  category    String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  entity    String
  action    String
  payload   Json?
  createdAt DateTime @default(now())
}

model Attachment {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  originalName   String
  fileName      String
  mimeType      String?
  filePath      String
  fileUrl       String
  createdAt     DateTime @default(now())
}
