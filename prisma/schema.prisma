generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AuthRole {
  admin
  staff
  viewer
}

enum UomType {
  count
  weight
  length
  volume
}

enum PurchaseOrderStatus {
  draft
  confirmed
  partial
  received
  cancelled
}

enum GoodsReceiptStatus {
  draft
  posted
}

enum SalesOrderStatus {
  draft
  confirmed
  invoiced
  cancelled
}

enum InvoiceStatus {
  unpaid
  partial
  paid
  cancelled
}

enum StockMovementType {
  opening
  purchase_in
  production_in
  sale_out
  return_in
  transfer_out
  transfer_in
  adjustment
}

enum ReturnType {
  customer_return
  supplier_return
}

enum StockTransferStatus {
  draft
  posted
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  passwordHash String
  role         AuthRole @default(staff)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Master Data ──────────────────────────────────────────────────────────────

model UnitOfMeasure {
  id           String   @id @default(cuid())
  name         String   @unique
  abbreviation String   @unique
  type         UomType  @default(count)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  variants ProductVariant[]
}

model ProductCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants ProductVariant[]
}

model ProductVariant {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  description  String?
  categoryId   String
  uomId        String
  reorderLevel Int      @default(0)
  costPrice    Decimal  @default(0) @db.Decimal(12, 2)
  salePrice    Decimal  @default(0) @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category           ProductCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uom                UnitOfMeasure      @relation(fields: [uomId], references: [id], onDelete: Restrict)
  stockLedger        StockLedger[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  salesOrderItems    SalesOrderItem[]
  salesInvoiceItems  SalesInvoiceItem[]
  stockTransferItems StockTransferItem[]
  returnItems        ReturnItem[]

  @@index([categoryId])
  @@index([uomId])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  mobile      String?
  email       String?
  address     String?
  taxId       String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  mobile      String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesOrders   SalesOrder[]
  salesInvoices SalesInvoice[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  transfersFrom  StockTransfer[] @relation("TransferFrom")
  transfersTo    StockTransfer[] @relation("TransferTo")
  stockLedger    StockLedger[]
}

// ─── Procurement ──────────────────────────────────────────────────────────────

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String
  warehouseId  String
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  status       PurchaseOrderStatus @default(draft)
  notes        String?
  totalAmount  Decimal             @default(0) @db.Decimal(12, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  supplier      Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouse     Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items         PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]

  @@index([supplierId])
  @@index([warehouseId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id               String   @id @default(cuid())
  purchaseOrderId  String
  productVariantId String
  orderedQty       Int
  unitCost         Decimal  @db.Decimal(12, 2)
  receivedQty      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder  PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([productVariantId])
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  grnNumber       String             @unique
  purchaseOrderId String
  warehouseId     String
  receiptDate     DateTime           @default(now())
  status          GoodsReceiptStatus @default(draft)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items         GoodsReceiptItem[]

  @@index([purchaseOrderId])
  @@index([warehouseId])
}

model GoodsReceiptItem {
  id               String   @id @default(cuid())
  goodsReceiptId   String
  productVariantId String
  receivedQty      Int
  unitCost         Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  goodsReceipt   GoodsReceipt   @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([goodsReceiptId])
  @@index([productVariantId])
}

// ─── Stock Ledger ─────────────────────────────────────────────────────────────

model StockLedger {
  id               String            @id @default(cuid())
  productVariantId String
  warehouseId      String?
  movementType     StockMovementType
  quantity         Int
  unitCost         Decimal           @default(0) @db.Decimal(12, 2)
  referenceType    String?
  referenceId      String?
  notes            String?
  movedAt          DateTime          @default(now())
  createdAt        DateTime          @default(now())

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  warehouse      Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([productVariantId])
  @@index([warehouseId])
  @@index([movementType])
  @@index([movedAt])
  @@index([referenceType, referenceId])
}

// ─── Stock Transfers ──────────────────────────────────────────────────────────

model StockTransfer {
  id              String              @id @default(cuid())
  transferNo      String              @unique
  fromWarehouseId String
  toWarehouseId   String
  transferDate    DateTime            @default(now())
  status          StockTransferStatus @default(draft)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  items         StockTransferItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model StockTransferItem {
  id               String   @id @default(cuid())
  stockTransferId  String
  productVariantId String
  quantity         Int
  createdAt        DateTime @default(now())

  stockTransfer  StockTransfer  @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([stockTransferId])
  @@index([productVariantId])
}

// ─── Sales ────────────────────────────────────────────────────────────────────

model SalesOrder {
  id          String           @id @default(cuid())
  orderNo     String           @unique
  customerId  String
  orderDate   DateTime         @default(now())
  status      SalesOrderStatus @default(draft)
  notes       String?
  totalAmount Decimal          @default(0) @db.Decimal(12, 2)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    SalesOrderItem[]
  invoices SalesInvoice[]

  @@index([customerId])
  @@index([status])
  @@index([orderDate])
}

model SalesOrderItem {
  id               String   @id @default(cuid())
  salesOrderId     String
  productVariantId String
  orderedQty       Int
  unitPrice        Decimal  @db.Decimal(12, 2)
  invoicedQty      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  salesOrder     SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([salesOrderId])
  @@index([productVariantId])
}

model SalesInvoice {
  id           String        @id @default(cuid())
  invoiceNo    String        @unique
  customerId   String
  salesOrderId String?
  invoiceDate  DateTime      @default(now())
  dueDate      DateTime?
  status       InvoiceStatus @default(unpaid)
  subtotal     Decimal       @default(0) @db.Decimal(12, 2)
  discountAmt  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount   Decimal       @default(0) @db.Decimal(12, 2)
  notes        String?
  isPosted     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesOrder SalesOrder?       @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  items      SalesInvoiceItem[]
  returns    Return[]

  @@index([customerId])
  @@index([salesOrderId])
  @@index([status])
  @@index([invoiceDate])
}

model SalesInvoiceItem {
  id               String   @id @default(cuid())
  salesInvoiceId   String
  productVariantId String
  quantity         Int
  unitPrice        Decimal  @db.Decimal(12, 2)
  costPrice        Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal        Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  salesInvoice   SalesInvoice   @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([salesInvoiceId])
  @@index([productVariantId])
}

// ─── Returns ──────────────────────────────────────────────────────────────────

model Return {
  id             String     @id @default(cuid())
  returnNo       String     @unique
  type           ReturnType
  salesInvoiceId String?
  returnDate     DateTime   @default(now())
  reason         String?
  notes          String?
  totalAmount    Decimal    @default(0) @db.Decimal(12, 2)
  isPosted       Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  salesInvoice SalesInvoice? @relation(fields: [salesInvoiceId], references: [id], onDelete: SetNull)
  items        ReturnItem[]

  @@index([salesInvoiceId])
  @@index([type])
}

model ReturnItem {
  id               String   @id @default(cuid())
  returnId         String
  productVariantId String
  quantity         Int
  unitPrice        Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())

  return         Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@index([productVariantId])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  actorName  String?
  snapshot   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
